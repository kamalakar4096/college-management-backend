{
  "info": {
    "name": "College Management API",
    "description": "Complete API collection for College Management Application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if(json.data && json.data.accessToken){ pm.collectionVariables.set('token', json.data.accessToken); }"
          ] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@college.edu\",\"password\":\"Admin@123\"}" }
          }
        }
      ]
    },
    {
      "name": "Users (Admin only)",
      "item": [
        {
          "name": "Create Dean",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"name\":\"Dr. John Dean\",\"email\":\"dean@college.edu\",\"password\":\"Dean@123\",\"phone\":\"9876543210\",\"role\":\"DEAN\"}" }
          }
        },
        {
          "name": "Create HOD",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"name\":\"Dr. Smith HOD\",\"email\":\"hod@college.edu\",\"password\":\"Hod@123\",\"phone\":\"9876543211\",\"role\":\"HOD\",\"departmentId\":1}" }
          }
        },
        {
          "name": "Create Faculty",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"name\":\"Prof. Alice Faculty\",\"email\":\"faculty@college.edu\",\"password\":\"Faculty@123\",\"phone\":\"9876543212\",\"role\":\"FACULTY\",\"departmentId\":1}" }
          }
        },
        {
          "name": "Create Student",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"name\":\"Bob Student\",\"email\":\"student@college.edu\",\"password\":\"Student@123\",\"phone\":\"9876543213\",\"role\":\"STUDENT\",\"departmentId\":1}" }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/users",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        },
        {
          "name": "Get Users by Role",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/users/role/STUDENT",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/users/2",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"name\":\"Updated Name\",\"phone\":\"9999999999\"}" }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/users/2/deactivate",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/users/2/activate",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "Create Department",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/departments",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"departmentName\":\"Computer Science\"}" }
          }
        },
        {
          "name": "Get All Departments",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/departments",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        },
        {
          "name": "Assign HOD to Department",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/departments/1/assign-hod/3",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        },
        {
          "name": "Update Department",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/departments/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"departmentName\":\"Computer Science & Engineering\"}" }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/courses",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"courseName\":\"Bachelor of Computer Science\",\"courseCode\":\"BCS101\",\"credits\":4,\"departmentId\":1}" }
          }
        },
        {
          "name": "Get All Courses",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/courses", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Get Courses by Department",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/courses/department/1", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        }
      ]
    },
    {
      "name": "Subjects (HOD)",
      "item": [
        {
          "name": "Create Subject",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/subjects",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"subjectName\":\"Data Structures\",\"semester\":3,\"departmentId\":1,\"facultyId\":4}" }
          }
        },
        {
          "name": "Get Subjects by Department",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/subjects/department/1", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Assign Faculty to Subject",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/subjects/1/assign-faculty/4",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Attendance (Faculty)",
      "item": [
        {
          "name": "Mark Attendance",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/attendance",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"subjectId\":1,\"date\":\"2025-01-15\",\"entries\":[{\"studentId\":5,\"status\":\"PRESENT\"},{\"studentId\":6,\"status\":\"ABSENT\"}]}" }
          }
        },
        {
          "name": "Get Student Attendance",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/attendance/student/5", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Get Attendance Percentage",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/attendance/percentage?studentId=5&subjectId=1", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Update Attendance",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/attendance/1?status=LATE",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Marks (Faculty)",
      "item": [
        {
          "name": "Add Marks",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/marks",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"studentId\":5,\"subjectId\":1,\"marks\":87.5,\"examType\":\"INTERNAL_1\"}" }
          }
        },
        {
          "name": "Get Marks by Student",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/marks/student/5", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Get Marks by Student+Subject",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/marks/student/5/subject/1", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Update Marks",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/marks/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"studentId\":5,\"subjectId\":1,\"marks\":90.0,\"examType\":\"INTERNAL_1\"}" }
          }
        }
      ]
    },
    {
      "name": "Assignments (Faculty + Student)",
      "item": [
        {
          "name": "Create Assignment (multipart)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/assignments",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "data", "value": "{\"title\":\"Assignment 1\",\"description\":\"Implement a linked list\",\"subjectId\":1,\"deadline\":\"2025-12-31T23:59:59\"}", "type": "text", "contentType": "application/json" },
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get Assignments by Faculty",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/assignments/faculty/4", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Submit Assignment (Student)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/assignments/1/submit",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }] }
          }
        },
        {
          "name": "Get Submissions for Assignment",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/assignments/1/submissions", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Get My Submission",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/assignments/1/my-submission", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/notifications",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
            "body": { "mode": "raw", "raw": "{\"title\":\"Exam Notice\",\"message\":\"Internal exams from Jan 20th\",\"targetRole\":\"STUDENT\",\"targetDepartmentId\":1}" }
          }
        },
        {
          "name": "Get Notifications for My Role",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/notifications/my-role", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Get Sent Notifications",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/notifications/sent", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        }
      ]
    },
    {
      "name": "Reports (Admin + Dean)",
      "item": [
        {
          "name": "Summary Report",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/reports/summary", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        },
        {
          "name": "Department Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/reports/department/1", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] }
        }
      ]
    }
  ]
}
